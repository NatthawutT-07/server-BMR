// generator client {
//   provider = "prisma-client-js"
// }

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  password            String
  role                String   @default("user")
  enabled             Boolean  @default(true)
  lastPasswordChange  DateTime @default(now())
  refreshTokenVersion Int      @default(0)

  loginLogs LoginLog[]
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  ip        String?
  userAgent String?
  status    String // success|failed
  message   String?
  createdAt DateTime @default(now())
}

model MinMaxAutoPO {
  id          Int    @id @default(autoincrement())
  branch_code String
  item_code   String
  min_stock   Int
  max_stock   Int
  pack_order  Int?

  @@unique([branch_code, item_code])
  @@index([branch_code, item_code])
}

model Stock {
  id             Int    @id @default(autoincrement())
  item_code      String
  branch_code    String
  quantity_stock Int

  @@unique([branch_code, item_code])
  @@index([branch_code, item_code])
}

model DataSync {
  key       String   @id
  updatedAt DateTime @default(now())
  rowCount  Int?
}

model BranchDataSync {
  branch_code String
  key         String
  updatedAt   DateTime @default(now())
  rowCount    Int?

  @@id([branch_code, key])
}

model Withdraw {
  id                 Int    @id @default(autoincrement())
  item_code          String
  branch_code        String
  document_reference String
  date_withdraw      String
  document_status    String
  reason             String
  quantity_withdraw  Int
  value_withdraw     Float

  @@unique([document_reference, branch_code, item_code, quantity_withdraw, value_withdraw])
  @@index([branch_code, item_code])
  @@index([branch_code, document_status, item_code])
}

model MasterItem {
  id                    Int     @id @default(autoincrement())
  item_code             String  @unique
  item_name             String?
  group_name            String?
  item_status           String?
  barcode               String?
  brand_name            String?
  is_consignment        String?
  purchase_price        Float
  selling_price_vat     Int
  preferred_vendor_code String?
  preferred_vendor_name String?
  gross_profit_pct      String?
  shelf_life_days       String?

  @@index([item_code])
}

model ShelfTemplate {
  id              Int     @id @default(autoincrement())
  branch_code     String
  shelf_code      String
  shelf_name      String?
  shelf_total_row Int
  type            String?

  @@unique([branch_code, shelf_code])
  @@index([branch_code, shelf_code, shelf_name])
}

model SkuPosition {
  id                 Int    @id @default(autoincrement())
  branch_code        String
  shelf_code         String
  shelf_row_number   Int
  item_code          String
  shelf_index_number Int

  @@index([branch_code, shelf_code, shelf_row_number, shelf_index_number])
  @@index([branch_code, shelf_code, shelf_index_number])
  @@index([branch_code, item_code])
}

model BranchMain {
  id          Int          @id @default(autoincrement())
  branch_code String       @unique
  branch_name String
  bills       BillHeader[]
}

model BillHeader {
  id                                   Int      @id @default(autoincrement())
  branchId                             Int
  date                                 DateTime
  bill_number                          String   @unique
  sales_channel                        String?
  doc_type                             String
  pos_type                             String
  reference_doc                        String?
  value_excl_tax                       Float
  vat                                  Float
  end_bill_discount                    Float
  total_sales_end_discount_no_rounding Float
  rounding                             Float
  total_sales_Finally                  Float

  branch    BranchMain @relation(fields: [branchId], references: [id])
  billItems BillItem[]

  @@index([branchId, doc_type, date])
  @@index([sales_channel])
  @@index([date])
  @@index([branchId, date])
  @@index([doc_type, date])
  @@index([date, id])
}

model BillItem {
  id                                   Int        @id @default(autoincrement())
  billId                               Int
  item_code                            String
  quantity_sale_bill                   Float
  unit                                 String?
  price_per_unit                       Float
  sales_amount                         Float
  discount                             Float
  total_sales_rounding_no_end_discount Float
  bill                                 BillHeader @relation(fields: [billId], references: [id])

  @@index([item_code])
  @@index([billId])
  @@index([billId, item_code])
}

model PogRequest {
  id             Int      @id @default(autoincrement())
  branch_code    String
  action         String // add|move|delete
  barcode        String
  item_name      String?
  fromShelf      String?
  fromRow        Int?
  fromIndex      Int?
  toShelf        String?
  toRow          Int?
  toIndex        Int?
  swap_barcode   String?
  swap_item_name String?
  status         String   @default("pending") // pending | approved | rejected | completed
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([branch_code, status])
  @@index([status])
  @@index([createdAt])
}

// สถานะอัพเดท shelf ของแต่ละสาขา
model ShelfUpdate {
  id          Int      @id @default(autoincrement())
  branch_code String   @unique
  hasUpdate   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([branch_code])
}

model Gourmet {
  id                    Int      @id @default(autoincrement())
  date                  DateTime
  branch_code           String
  item_code             String
  quantity_sale_gourmet Int
  sales_amount_gourmet  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, branch_code, item_code, quantity_sale_gourmet])
  @@index([date])
  @@index([branch_code])
  @@index([item_code])
}

// log การเปลี่ยนแปลง shelf (add/delete/move)
model ShelfChangeLog {
  id             Int       @id @default(autoincrement())
  branch_code    String
  shelf_code     String
  updateId       String
  action         String // add | delete | move
  item_code      String
  item_name      String?
  fromRow        Int?
  fromIndex      Int?
  toRow          Int?
  toIndex        Int?
  createdAt      DateTime  @default(now())
  createdBy      String?
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?

  @@index([branch_code, shelf_code])
  @@index([branch_code, createdAt])
  @@index([branch_code, acknowledged])
  @@index([updateId])
}

// ========== HQ System Models ==========

model employee_hq {
  id                  Int     @id @default(autoincrement())
  employee_code       String  @unique
  nickname            String
  position            String
  organizational_unit String
  point_earned        Int     @default(0)
  point_redeemed      Int     @default(0)
  role                String  @default("user")
  password            String?
  status              String  @default("active")

  logs log_hq[]

  @@index([employee_code])
  @@index([role])
}

model reward_hq {
  id           Int     @id @default(autoincrement())
  title        String
  point_reward Int
  image_url    String?

  @@index([point_reward])
}

model branch_hq {
  id          Int    @id @default(autoincrement())
  branch_code String
  branch_name String
  month       Int
  day         Int
  target      Float
  avg_target  Float
  status      String @default("active")

  @@unique([branch_code, month])
  @@index([branch_code])
  @@index([month])
}

model log_hq {
  id            Int         @id @default(autoincrement())
  employee_code String
  employee      employee_hq @relation(fields: [employee_code], references: [employee_code], onDelete: Cascade)
  branch_code   String?
  branch_name   String?
  date          DateTime
  action        String
  target        Float?
  sales         Float?
  point         Int?
  reward        String?
  created_at    DateTime    @default(now())

  @@index([employee_code])
  @@index([branch_code])
  @@index([date])
  @@index([action])
}
