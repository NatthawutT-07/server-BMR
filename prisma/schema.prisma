// generator client {
//   provider = "prisma-client-js"
// }

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int      @id @default(autoincrement())
  name                String   @unique
  password            String
  role                String   @default("user")
  enabled             Boolean  @default(true)
  lastPasswordChange  DateTime @default(now())
  refreshTokenVersion Int      @default(0)

  loginLogs LoginLog[]
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id])
  userId    Int?
  ip        String?
  userAgent String?
  status    String // success|failed
  message   String?
  createdAt DateTime @default(now())
}

model ItemMinMax {
  id          Int    @id @default(autoincrement())
  branch_code String
  item_code   String
  min_stock   Int
  max_stock   Int
  pack_order  Int?

  @@unique([branch_code, item_code])
  @@index([branch_code, item_code])
}

model Stock {
  id             Int    @id @default(autoincrement())
  item_code      String
  branch_code    String
  quantity_stock Int

  @@unique([branch_code, item_code])
  @@index([branch_code, item_code])
}

model DataSync {
  key       String   @id
  updatedAt DateTime @default(now())
  rowCount  Int?
}

model BranchDataSync {
  branch_code String
  key         String
  updatedAt   DateTime @default(now())
  rowCount    Int?

  @@id([branch_code, key])
}

model withdraw {
  id                Int    @id @default(autoincrement())
  item_code         String
  branch_code       String
  docNumber         String
  date              String
  docStatus         String
  reason            String
  quantity_withdraw Int
  value_withdraw             Float

  @@unique([docNumber, branch_code, item_code, quantity_withdraw, value_withdraw])
  @@index([branch_code, item_code])
  @@index([branch_code, docStatus, item_code])
}

model ListOfItemHold {
  id                  Int     @id @default(autoincrement())
  item_code           String  @unique
  nameProduct         String?
  groupName           String?
  status              String?
  barcode             String?
  nameBrand           String?
  consingItem         String?
  purchasePriceExcVAT Float
  salesPriceIncVAT    Int
  preferredVandorCode String?
  preferredVandorName String?
  GP                  String?
  shelfLife           String?
  productionDate      String?
  vatGroupPu          String?

  @@index([item_code])
}

model Template {
  id          Int     @id @default(autoincrement())
  branch_code String
  shelfCode   String
  fullName    String?
  rowQty      Int
  type        String?

  @@unique([branch_code, shelfCode])
  @@index([branch_code, shelfCode, fullName])
}

model Sku {
  id          Int    @id @default(autoincrement())
  branch_code String
  shelfCode   String
  rowNo       Int
  item_code   String
  index       Int

  @@unique([branch_code, item_code])
  @@index([branch_code, shelfCode, rowNo, index])
  @@index([branch_code, shelfCode, index])
  @@index([branch_code, item_code]) 
}

model Branch {
  id          Int    @id @default(autoincrement())
  branch_code String @unique
  branch_name String
  bills       Bill[]
}

model Bill {
  id                   Int      @id @default(autoincrement())
  branchId             Int
  date                 DateTime
  bill_number          String   @unique
  sales_channel        String?
  doc_type             String
  pos_type             String
  reference_doc        String?
  value_excl_tax       Float
  vat                  Float
  end_bill_discount    Float
  total_sales_end_discount_no_rounding Float
  rounding             Float
  total_sales_Finally          Float

  branch    Branch     @relation(fields: [branchId], references: [id])
  billItems BillItem[]

  @@index([branchId, doc_type, date])
  @@index([sales_channel])
  @@index([date])
  @@index([branchId, date])
  @@index([doc_type, date])
  @@index([date, id])
}

model BillItem {
  id                 Int     @id @default(autoincrement())
  billId             Int
  item_code          String
  quantity_sale_bill Float
  unit               String?
  price_per_unit     Float
  sales_amount       Float
  discount           Float
  total_sales_rounding_no_end_discount          Float
  bill               Bill    @relation(fields: [billId], references: [id])

  @@index([item_code])
  @@index([billId])
  @@index([billId, item_code])
}

model PogRequest {
  id          Int     @id @default(autoincrement())
  branch_code String
  action      String // add|move|delete
  barcode     String
  productName String?

  // Current position
  fromShelf String?
  fromRow   Int?
  fromIndex Int?

  // Target position (for add/swap)
  toShelf String?
  toRow   Int?
  toIndex Int?

  // For swap - second product
  swapBarcode     String?
  swapProductName String?

  status    String   @default("pending") // pending | approved | rejected | completed
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branch_code, status])
  @@index([status])
  @@index([createdAt])
}

// เก็บสถานะการอัพเดท shelf ของแต่ละสาขา (สำหรับแจ้งเตือน mobile)
model ShelfUpdate {
  id          Int      @id @default(autoincrement())
  branch_code String   @unique
  hasUpdate   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([branch_code])
}

model Gourmet {
  id                    Int      @id @default(autoincrement())
  date                  DateTime
  branch_code           String
  item_code             String
  quantity_sale_gourmet Int
  sales_amount_gourmet                 Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, branch_code, item_code, quantity_sale_gourmet])
  @@index([date])
  @@index([branch_code])
  @@index([item_code])
}

// เก็บ log รายละเอียดการเปลี่ยนแปลง shelf (add/delete/move)
model ShelfChangeLog {
  id          Int     @id @default(autoincrement())
  branch_code String
  shelfCode   String
  updateId    String // UUID group บันทึกพร้อมกัน
  action      String // add | delete | move
  item_code   String
  productName String?

  // ตำแหน่งเดิม (สำหรับ delete/move)
  fromRow   Int?
  fromIndex Int?

  // ตำแหน่งใหม่ (สำหรับ add/move)
  toRow   Int?
  toIndex Int?

  createdAt DateTime @default(now())
  createdBy String?

  //  สำหรับ acknowledge ทีละตัว
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?

  @@index([branch_code, shelfCode])
  @@index([branch_code, createdAt])
  @@index([branch_code, acknowledged])
  @@index([updateId])
}

// ========== HQ System Models ==========

model employee_hq {
  id                  Int     @id @default(autoincrement())
  employee_code       String  @unique
  nickname            String
  position            String
  organizational_unit String
  point_earned        Int     @default(0)
  point_redeemed      Int     @default(0)
  role                String  @default("user")
  password            String?
  status              String  @default("active")

  logs log_hq[]

  @@index([employee_code])
  @@index([role])
}

model reward_hq {
  id           Int     @id @default(autoincrement())
  title        String
  point_reward Int
  image_url    String?

  @@index([point_reward])
}

model branch_hq {
  id          Int    @id @default(autoincrement())
  branch_code String
  branch_name String
  month       Int
  day         Int
  target      Float
  avg_target  Float
  status      String @default("active")

  @@unique([branch_code, month])
  @@index([branch_code])
  @@index([month])
}

model log_hq {
  id            Int         @id @default(autoincrement())
  employee_code String
  employee      employee_hq @relation(fields: [employee_code], references: [employee_code], onDelete: Cascade)
  branch_code   String?
  branch_name   String?
  date          DateTime
  action        String
  target        Float?
  sales         Float?
  point         Int?
  reward        String?
  created_at    DateTime    @default(now())

  @@index([employee_code])
  @@index([branch_code])
  @@index([date])
  @@index([action])
}
